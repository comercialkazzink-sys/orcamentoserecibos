@echo off\nchcp 65001 > nul\ncolor 0A\necho.\necho ============================================\necho   📦 INSTALADOR - Orçamentos e Recibos\necho ============================================\necho.\n\nREM Verificar se Git está instalado\nwhere git >nul 2>nul\nif %errorlevel% neq 0 (\n    echo ❌ Git não está instalado!\n    echo Baixe em: https://git-scm.com/download\n    pause\n    exit /b 1\n)\n\nREM Verificar se Node.js está instalado\nwhere node >nul 2>nul\nif %errorlevel% neq 0 (\n    echo ❌ Node.js não está instalado!\n    echo Baixe em: https://nodejs.org\n    pause\n    exit /b 1\n)\n\necho ✅ Git detectado\necho ✅ Node.js detectado\necho.\necho 📥 Clonando repositório...\necho.\n\ngit clone https://github.com/comercialkazzink-sys/orcamentoserecibos.git\n\nif %errorlevel% neq 0 (\n    echo ❌ Erro ao clonar repositório!\n    pause\n    exit /b 1\n)\n\ncd orcamentoserecibos\n\necho.\necho 📦 Instalando dependências...\necho.\n\nnpm install\n\nif %errorlevel% neq 0 (\n    echo ❌ Erro ao instalar dependências!\n    pause\n    exit /b 1\n)\n\necho.\necho ⚙️  Configurando variáveis de ambiente...\necho.\n\nif not exist .env (\n    copy .env.example .env\n    echo ✅ Arquivo .env criado!\n    echo.\n    echo ⚠️  IMPORTANTE: Edite o arquivo .env com suas configurações:\n    echo    - MONGODB_URI (endereço do MongoDB)\n    echo    - JWT_SECRET (chave secreta)\n    echo.\n) else (\n    echo ✅ Arquivo .env já existe\n)\n\necho.\necho ============================================\necho   ✅ INSTALAÇÃO CONCLUÍDA COM SUCESSO!\necho ============================================\necho.\necho 🚀 Para iniciar o servidor, execute:\necho.\necho    cd orcamentoserecibos\necho    npm run dev\necho.\necho 📱 Acesse: http://localhost:5000\necho.\necho 📖 Documentação completa em README.md\necho.\npause\n"